# AUTONOMOUS AGENT ENGINE
# ============================================================

class AutonomousAgent:
      """Individual agent with assigned roles and capabilities"""

    def __init__(self, agent_id, name):
              self.agent_id = agent_id
              self.name = name
              self.status = "IDLE"
              self.tasks_completed = 0
              self.tasks_failed = 0
              self.current_task = None

    def execute_task(self, task):
              """Execute assigned task"""
              self.status = "WORKING"
              self.current_task = task

        try:
                      task_type = task.get("type", "general")

            if task_type == "outreach":
                              self.tasks_completed += 1
                              logger.info(f"[{self.name}] ✓ Completed outreach: {task['details']}")
elif task_type == "qualification":
                  self.tasks_completed += 1
                  logger.info(f"[{self.name}] ✓ Qualified lead: {task['lead_id']}")
elif task_type == "proposal":
                  self.tasks_completed += 1
                  logger.info(f"[{self.name}] ✓ Sent proposal: {task['value']}")
elif task_type == "closing":
                  self.tasks_completed += 1
                  logger.info(f"[{self.name}] ✓ Closed deal: {task['value']}")
else:
                  self.tasks_completed += 1
                  logger.info(f"[{self.name}] ✓ Task completed: {task_type}")

except Exception as e:
            self.tasks_failed += 1
            logger.error(f"[{self.name}] ✗ Task failed: {e}")

        self.status = "IDLE"
        self.current_task = None

    def get_status(self):
              """Return agent status"""
              return {
                  "name": self.name,
                  "status": self.status,
                  "tasks_completed": self.tasks_completed,
                  "tasks_failed": self.tasks_failed
              }

