# ORCHESTRATOR ENGINE
# ============================================================

class ZYNOrchestrator:
      """Main orchestration engine coordinating all integrations"""

    def __init__(self):
              self.agents = [AutonomousAgent(i+1, name) for i, name in enumerate(AGENT_NAMES)]
              self.google_sheets = GoogleSheetsConnector(GOOGLE_SHEETS_ID)
              self.discord = DiscordIntegration()
              self.sam_gov = SAMGovConnector()
              self.insights = InsightsDashboard()
              self.task_queue = Queue()
              self.is_running = False
              logger.info("✓ ZYN Orchestrator initialized with full integrations")

    def initialize_integrations(self):
              """Initialize all external integrations"""
              logger.info("\n" + "="*60)
              logger.info("INITIALIZING EXTERNAL INTEGRATIONS")
              logger.info("="*60)

        # Google Sheets
              self.google_sheets.fetch_leads()

        # Discord
        self.discord.send_message("integration", "🔗 ZYN Agents integration starting...")

        # SAM.gov
        self.sam_gov.scan_opportunities()

        # Insights
        self.insights.publish_to_dashboard()

        logger.info("✓ All integrations initialized successfully\n")

    def queue_tasks_from_sheets(self):
              """Pull tasks from Google Sheets and queue them"""
              leads = self.google_sheets.leads

        task_types = ["outreach", "qualification", "proposal", "closing"]
        task_count = 0

        for i, lead in enumerate(leads):
                      agent = self.agents[i % len(self.agents)]
                      task = {
                          "id": f"TASK_{i+1}",
                          "type": task_types[i % len(task_types)],
                          "agent_id": agent.agent_id,
                          "lead_id": lead["id"],
                          "company": lead["company"],
                          "value": lead["value"],
                          "details": f"Process {lead['company']} - ${lead['value']}"
                      }
                      self.task_queue.put(task)
                      task_count += 1

        logger.info(f"✓ Queued {task_count} tasks from Google Sheets")

    def execute_task_queue(self):
              """Execute all queued tasks"""
              executed = 0
              while not self.task_queue.empty():
                            task = self.task_queue.get()
                            agent = self.agents[task["agent_id"] - 1]
                            agent.execute_task(task)
                            executed += 1

              logger.info(f"✓ Executed {executed} tasks from queue")
              return executed

    def post_execution_reports(self):
              """Post agent reports to Discord"""
              for agent in self.agents:
                            if agent.tasks_completed > 0:
                                              self.discord.post_agent_report(agent.name, agent.tasks_completed, agent.tasks_failed)

                    def run(self):
                              """Run the complete orchestration cycle"""
                              self.is_running = True

        logger.info("\n" + "="*60)
        logger.info("ZYN EMPIRE - AUTONOMOUS AGENTS ENGINE STARTED")
        logger.info("="*60)
        logger.info(f"Startup time: {datetime.now().isoformat()}")
        logger.info(f"Total agents: {len(self.agents)}")
        logger.info(f"Google Sheets: {GOOGLE_SHEETS_ID}")
        logger.info(f"Discord Channels: {len(self.discord.channels)}")
        logger.info(f"SAM.gov API: Enabled")
        logger.info(f"Insights Dashboard: Live")
        logger.info("="*60 + "\n")

        # Initialize integrations
        self.initialize_integrations()

        # Queue tasks
        self.queue_tasks_from_sheets()

        # Execute tasks
        logger.info("="*60)
        logger.info("EXECUTING TASKS")
        logger.info("="*60)
        self.execute_task_queue()

        # Post reports
        logger.info("\n" + "="*60)
        logger.info("AGENT EXECUTION SUMMARY")
        logger.info("="*60)
        for agent in self.agents:
                      status = agent.get_status()
                      if status["tasks_completed"] > 0:
                                        logger.info(f"{status['name']}: {status['tasks_completed']} completed, {status['tasks_failed']} failed")

                  # Final dashboard update
                  self.insights.update_metrics({
                                "tasks_executed": sum(a.tasks_completed for a in self.agents),
                                "last_run": datetime.now().isoformat()
                  })
        self.insights.publish_to_dashboard()

        logger.info("\n" + "="*60)
        logger.info("✓ ZYN EMPIRE FULLY OPERATIONAL - ALL INTEGRATIONS ACTIVE")
        logger.info("="*60)
        logger.info("[INFO] Google Sheets: Connected and synced")
        logger.info("[INFO] Discord: All 20 channels active")
        logger.info("[INFO] SAM.gov: Scanning enabled")
        logger.info("[INFO] Insights Dashboard: Real-time metrics publishing")
        logger.info("="*60 + "\n")

        self.is_running = False

