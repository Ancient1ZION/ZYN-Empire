# ZYN EMPIRE CONFIGURATION
# Copy this file to .env and fill in actual values

# GROQ API (Primary LLM)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=mixtral-8x7b-32768

# GOOGLE GEMINI (Fallback LLM)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# GOOGLE APPS SCRIPT
GAS_DEPLOYMENT_ID=your_gas_web_app_id
GAS_WEBHOOK_URL=https://script.google.com/macros/d/{deploymentId}/usercontent

# GOOGLE SHEETS
GOOGLE_SHEET_ID=1WHN438mjORT4HnGiXapWv78uomVy6KMhHsl0llxaeQk
GOOGLE_CREDS_PATH=./config/google-creds.json

# DISCORD
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_guild_id
DISCORD_WEBHOOK_MASTER=https://discord.com/api/webhooks/...

# SAM.GOV
SAM_GOV_API_KEY=your_sam_gov_api_key
SAM_GOV_ENTITY_ID=your_sam_entity_id

# GCP CONFIGURATION
GCP_PROJECT_ID=zyn-empire-prod
GCP_REGION=us-central1
GCP_VM_IP=35.185.40.28
GCP_SSH_KEY_PATH=./config/gcp-ssh-key

# SYSTEM CONFIGURATION
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=10

# AGENT CONFIGURATION
MAX_CONCURRENT_AGENTS=19
AGENT_TIMEOUT_SECONDS=300
AGENT_MEMORY_MB=512

# SAFETY & MONITORING
PROMPT_GUARD_ENABLED=true
DRIFT_DETECTION_ENABLED=true
META_LEARNING_ENABLED=true
AUTOREPAIR_ENABLED=true

# MONITORING
HEALTH_CHECK_INTERVAL_SECONDS=60
DRIFT_CHECK_INTERVAL_HOURS=1
META_LEARNING_UPDATE_INTERVAL_HOURS=24

# STRIPE (Optional - for SaaS features)
STRIPE_API_KEY=your_stripe_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret

# PAGERDUTY (Optional - for alerts)
PAGERDUTY_API_KEY=your_pagerduty_key
PAGERDUTY_SERVICE_ID=your_service_id
